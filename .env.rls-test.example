# .env.rls-test.example — config for scripts/rls-adversarial-test.mjs (Phase 2 Step 3 RLS gate)
#
# Copy this file to .env.rls-test and fill in real values. .env.rls-test is
# gitignored (matched by .env*), so secrets stay local. NEVER point this at production.
#
# Where to get these: Supabase dashboard → project "translationapp1-staging" →
#   Project Settings → API  (URL + anon key + service_role key).

# --- Staging Supabase project ---
STAGING_SUPABASE_URL=https://<your-staging-ref>.supabase.co
STAGING_SUPABASE_ANON_KEY=<staging anon/public key>
# service_role bypasses RLS — used ONLY for one-time fixture setup, never for assertions.
STAGING_SUPABASE_SERVICE_ROLE_KEY=<staging service_role key>

# --- Test users ---
# A and B should already exist on staging (created during the Step 2 / inference smoke test).
# C is created automatically by the script and re-pointed to throwaway tenant 2.
# The script sets all three to RLS_TEST_PASSWORD via the admin API and confirms their emails.
RLS_TEST_A_EMAIL=rls-a@example.com
RLS_TEST_B_EMAIL=rls-b@example.com
RLS_TEST_C_EMAIL=rls-c@example.com
RLS_TEST_PASSWORD=<a strong throwaway password, reused for all 3 test users>

# --- Step 6 abandonment sweep (scripts/abandonment-gate-test.mjs) ---
# HMAC pepper for email_hash_abuse — computed in the job layer, NEVER stored in Postgres.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The same value must be set in Vercel Preview env as ABANDONMENT_EMAIL_HASH_PEPPER.
ABANDONMENT_EMAIL_HASH_PEPPER=<32-byte hex pepper>
ABANDONMENT_EMAIL_HASH_KEY_VERSION=1

# --- Safety interlock ---
# The script mutates the DB (passwords, tenant 2, user C, RLS-TEST messages).
# It refuses to run unless this is exactly "yes". Set it ONLY when pointed at staging.
RLS_TEST_CONFIRM_STAGING=no
